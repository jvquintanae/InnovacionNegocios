<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Balance — Prototipo App de organización gamificada</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,400&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #1a1410;
  --ink-soft: #4a3f37;
  --ink-muted: #8a7d72;
  --cream: #f5efe6;
  --cream-2: #ebe2d3;
  --paper: #fdfaf4;
  --moss: #4d6b4a;
  --moss-deep: #2f4530;
  --moss-light: #a8c19e;
  --terra: #d97757;
  --terra-deep: #b85a3d;
  --gold: #d4a437;
  --berry: #a8456e;
  --sky: #7ba6c4;
  --shadow: 0 4px 20px rgba(26, 20, 16, 0.08);
  --shadow-lg: 0 12px 40px rgba(26, 20, 16, 0.15);
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background:
    radial-gradient(circle at 15% 10%, rgba(168, 193, 158, 0.25), transparent 40%),
    radial-gradient(circle at 85% 80%, rgba(217, 119, 87, 0.18), transparent 45%),
    linear-gradient(135deg, #ebe2d3 0%, #f5efe6 50%, #ebe2d3 100%);
  min-height: 100vh;
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    radial-gradient(circle, rgba(26, 20, 16, 0.04) 1px, transparent 1px);
  background-size: 24px 24px;
  pointer-events: none;
  z-index: 0;
}

.frame-container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}

.brand {
  text-align: center;
  font-family: 'Fraunces', serif;
}

.brand-name {
  font-size: 36px;
  font-weight: 900;
  font-style: italic;
  color: var(--moss-deep);
  letter-spacing: -1px;
  line-height: 1;
}

.brand-name span {
  color: var(--terra);
  font-style: normal;
}

.brand-tag {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 3px;
  color: var(--ink-muted);
  margin-top: 6px;
}

.phone {
  width: 380px;
  height: 760px;
  background: var(--paper);
  border-radius: 48px;
  box-shadow:
    var(--shadow-lg),
    0 0 0 8px #1a1410,
    0 0 0 10px #3d342c;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
}

.notch {
  position: absolute;
  top: 8px;
  left: 50%;
  transform: translateX(-50%);
  width: 110px;
  height: 26px;
  background: #1a1410;
  border-radius: 0 0 18px 18px;
  z-index: 100;
}

.status-bar {
  padding: 14px 28px 6px;
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  font-weight: 600;
  color: var(--ink);
  position: relative;
  z-index: 10;
}

.screen {
  flex: 1;
  overflow-y: auto;
  display: none;
  flex-direction: column;
  padding-bottom: 90px;
  position: relative;
}

.screen.active { display: flex; }

.screen::-webkit-scrollbar { display: none; }

/* === HOME === */
.home-header {
  padding: 16px 24px 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.greeting-block .hello {
  font-family: 'Fraunces', serif;
  font-size: 26px;
  font-weight: 600;
  font-style: italic;
  color: var(--ink);
  line-height: 1;
}

.greeting-block .name {
  font-family: 'Fraunces', serif;
  font-size: 26px;
  font-weight: 900;
  color: var(--moss-deep);
  line-height: 1;
}

.greeting-block .date {
  font-size: 11px;
  color: var(--ink-muted);
  margin-top: 4px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}

.streak-chip {
  background: var(--ink);
  color: var(--cream);
  padding: 8px 12px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 4px;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.pause-btn {
  background: var(--cream-2);
  border: none;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--moss-deep);
  cursor: pointer;
  transition: all 0.2s;
}

.pause-btn:active { transform: scale(0.92); }
.pause-btn.active {
  background: var(--moss-deep);
  color: var(--cream);
}

.streak-chip-soft {
  background: rgba(168, 193, 158, 0.35);
  color: var(--moss-deep);
  padding: 8px 12px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 4px;
}

/* Banner modo pausa */
.pause-banner {
  margin: 0 20px 12px;
  background: linear-gradient(135deg, #a8c19e, #4d6b4a);
  color: var(--paper);
  padding: 14px 18px;
  border-radius: 18px;
  font-size: 13px;
  display: none;
  align-items: center;
  gap: 12px;
}

.pause-banner.visible { display: flex; }

.pause-banner-icon {
  font-size: 22px;
  flex-shrink: 0;
}

.pause-banner-text {
  flex: 1;
  line-height: 1.4;
}

.pause-banner-text strong {
  display: block;
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 2px;
}

/* Alerta de sobrecarga */
.smart-alert {
  margin: 0 20px 12px;
  background: linear-gradient(135deg, #fff4e6, #ffe8cc);
  border-left: 4px solid var(--terra);
  padding: 14px 16px;
  border-radius: 14px;
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.smart-alert.hidden { display: none; }

.smart-alert-icon {
  font-size: 24px;
  flex-shrink: 0;
}

.smart-alert-body { flex: 1; }

.smart-alert-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--terra-deep);
  margin-bottom: 4px;
}

.smart-alert-text {
  font-size: 12px;
  color: var(--ink-soft);
  line-height: 1.4;
  margin-bottom: 8px;
}

.smart-alert-actions {
  display: flex;
  gap: 6px;
}

.alert-btn {
  background: var(--terra);
  color: var(--cream);
  border: none;
  padding: 6px 12px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
}

.alert-btn.secondary {
  background: transparent;
  color: var(--ink-soft);
  border: 1px solid var(--cream-2);
}

.mascot-card {
  margin: 16px 20px;
  background: linear-gradient(160deg, #4d6b4a 0%, #2f4530 100%);
  border-radius: 28px;
  padding: 22px 20px;
  position: relative;
  overflow: hidden;
  color: var(--cream);
  min-height: 140px;
  box-sizing: border-box;
}

.mascot-card::before {
  content: '';
  position: absolute;
  top: -40px;
  right: -40px;
  width: 160px;
  height: 160px;
  background: radial-gradient(circle, rgba(212, 164, 55, 0.3), transparent 70%);
  border-radius: 50%;
}

.mascot-stage {
  display: flex;
  align-items: center;
  gap: 16px;
  position: relative;
  z-index: 2;
}

.mascot-svg {
  width: 80px;
  height: 80px;
  flex-shrink: 0;
  background: rgba(245, 239, 230, 0.12);
  border-radius: 20px;
  padding: 6px;
  box-sizing: border-box;
}

.mascot-info {
  flex: 1;
  min-width: 0;
}

.mascot-info .mascot-name {
  font-family: 'Fraunces', serif;
  font-size: 28px;
  font-weight: 800;
  font-style: italic;
  line-height: 1;
  color: var(--cream);
  display: block;
}

.mascot-info .mascot-level {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  opacity: 0.85;
  margin-top: 6px;
  display: block;
}

.xp-bar {
  margin-top: 10px;
  height: 5px;
  background: rgba(245, 239, 230, 0.2);
  border-radius: 3px;
  overflow: hidden;
}

.xp-fill {
  height: 100%;
  width: 68%;
  background: var(--gold);
  border-radius: 3px;
  box-shadow: 0 0 8px rgba(212, 164, 55, 0.6);
}

.mascot-info .xp-text {
  font-size: 10px;
  opacity: 0.7;
  margin-top: 4px;
  display: block;
}

.energy-section {
  margin: 8px 20px;
  background: var(--paper);
  border: 1.5px solid var(--cream-2);
  border-radius: 20px;
  padding: 16px;
}

.energy-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.energy-label .lbl {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--ink-muted);
  font-weight: 600;
}

.energy-label .val {
  font-family: 'Fraunces', serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--moss-deep);
}

.energy-bar {
  height: 10px;
  background: var(--cream-2);
  border-radius: 5px;
  overflow: hidden;
  display: flex;
}

.energy-segment {
  flex: 1;
  margin-right: 2px;
  border-radius: 2px;
  transition: background 0.3s;
}

.energy-segment.filled { background: var(--moss); }
.energy-segment.medium { background: var(--gold); }
.energy-segment.empty { background: var(--cream-2); }

.energy-tip {
  margin-top: 10px;
  font-size: 12px;
  color: var(--ink-soft);
  font-style: italic;
  line-height: 1.4;
}

.section-title {
  font-family: 'Fraunces', serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--ink);
  padding: 16px 24px 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title .ver-todo {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 11px;
  font-weight: 600;
  color: var(--terra);
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
}

.quick-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  padding: 0 20px;
}

.stat-card {
  background: var(--paper);
  border: 1.5px solid var(--cream-2);
  border-radius: 16px;
  padding: 12px;
  text-align: center;
}

.stat-card .num {
  font-family: 'Fraunces', serif;
  font-size: 24px;
  font-weight: 900;
  color: var(--moss-deep);
  line-height: 1;
}

.stat-card .lbl {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--ink-muted);
  margin-top: 4px;
  font-weight: 600;
}

.stat-card.terra .num { color: var(--terra); }
.stat-card.gold .num { color: var(--gold); }

.mission-list {
  padding: 0 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.mission {
  background: var(--paper);
  border: 1.5px solid var(--cream-2);
  border-radius: 16px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  transition: all 0.2s;
}

.mission:active { transform: scale(0.98); }

.mission.done {
  opacity: 0.5;
  background: var(--cream);
}

.mission.done .mission-title { text-decoration: line-through; }

.mission-check {
  width: 24px;
  height: 24px;
  border-radius: 8px;
  border: 2px solid var(--cream-2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.mission.done .mission-check {
  background: var(--moss);
  border-color: var(--moss);
}

.mission.done .mission-check::after {
  content: '✓';
  color: white;
  font-size: 14px;
  font-weight: 900;
}

.mission-body { flex: 1; }

.mission-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--ink);
}

.mission-meta {
  font-size: 11px;
  color: var(--ink-muted);
  margin-top: 2px;
  display: flex;
  gap: 8px;
}

.mission-points {
  background: var(--gold);
  color: var(--ink);
  padding: 4px 8px;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 700;
}

.mission-points.descanso { background: var(--moss-light); color: var(--moss-deep); }
.mission-points.hobby { background: var(--terra); color: var(--cream); }

/* === PENDIENTES === */
.screen-header {
  padding: 16px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.screen-title {
  font-family: 'Fraunces', serif;
  font-size: 32px;
  font-weight: 900;
  font-style: italic;
  color: var(--ink);
  line-height: 1;
}

.screen-subtitle {
  font-size: 12px;
  color: var(--ink-muted);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-top: 6px;
}

.add-btn {
  width: 48px;
  height: 48px;
  background: var(--terra);
  color: var(--cream);
  border: none;
  border-radius: 16px;
  font-size: 26px;
  font-weight: 300;
  cursor: pointer;
  box-shadow: 0 4px 12px rgba(217, 119, 87, 0.4);
  transition: transform 0.2s;
}

.add-btn:active { transform: scale(0.92); }

.category-pills-wrap {
  position: relative;
  padding: 8px 0 16px;
}

.category-pills-wrap::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  bottom: 16px;
  width: 30px;
  background: linear-gradient(to right, transparent, var(--paper) 80%);
  pointer-events: none;
  z-index: 2;
}

.category-pills {
  padding: 0 20px;
  display: flex;
  gap: 8px;
  overflow-x: auto;
  scroll-padding: 20px;
}

.category-pills::-webkit-scrollbar { display: none; }

.pill {
  padding: 9px 16px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
  border: 1.5px solid var(--cream-2);
  background: var(--paper);
  color: var(--ink-soft);
  cursor: pointer;
  transition: all 0.2s;
  flex-shrink: 0;
}

.pill.active {
  background: var(--ink);
  color: var(--cream);
  border-color: var(--ink);
}

.task-group {
  padding: 0 20px;
}

.task-group-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--ink-muted);
  font-weight: 700;
  padding: 12px 0 8px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.task-group-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--cream-2);
}

.task-card {
  background: var(--paper);
  border: 1.5px solid var(--cream-2);
  border-radius: 18px;
  padding: 14px 16px;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  position: relative;
}

.task-card.done { opacity: 0.5; background: var(--cream); }
.task-card.done .task-name { text-decoration: line-through; }

.task-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}

.task-icon.estudio { background: rgba(123, 166, 196, 0.2); color: var(--sky); }
.task-icon.trabajo { background: rgba(168, 69, 110, 0.2); color: var(--berry); }
.task-icon.habito { background: rgba(77, 107, 74, 0.15); color: var(--moss); }
.task-icon.descanso { background: rgba(212, 164, 55, 0.2); color: var(--gold); }
.task-icon.hobby { background: rgba(217, 119, 87, 0.2); color: var(--terra); }

.task-body { flex: 1; min-width: 0; }

.task-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--ink);
}

.task-time {
  font-size: 11px;
  color: var(--ink-muted);
  margin-top: 2px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.task-pts {
  background: var(--cream-2);
  color: var(--ink);
  padding: 4px 10px;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 700;
  font-family: 'Fraunces', serif;
}

/* === CALENDARIO === */
.cal-week {
  padding: 8px 20px 16px;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4px;
}

.cal-day {
  text-align: center;
  padding: 10px 4px;
  border-radius: 14px;
  cursor: pointer;
  position: relative;
}

.cal-day .dow {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--ink-muted);
  font-weight: 600;
}

.cal-day .dom {
  font-family: 'Fraunces', serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--ink);
  margin-top: 4px;
}

.cal-day.today {
  background: var(--ink);
}

.cal-day.today .dow,
.cal-day.today .dom {
  color: var(--cream);
}

.cal-day .dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--terra);
  margin: 4px auto 0;
}

.cal-day.today .dot { background: var(--gold); }

.timeline {
  padding: 0 20px;
  position: relative;
}

.time-block {
  display: flex;
  gap: 12px;
  margin-bottom: 10px;
  align-items: stretch;
}

.time-label {
  width: 48px;
  font-size: 11px;
  color: var(--ink-muted);
  font-weight: 600;
  text-align: right;
  padding-top: 14px;
  flex-shrink: 0;
}

.time-event {
  flex: 1;
  border-radius: 14px;
  padding: 12px 14px;
  color: white;
  position: relative;
}

.time-event.estudio { background: linear-gradient(135deg, #7ba6c4, #5e89a8); }
.time-event.trabajo { background: linear-gradient(135deg, #a8456e, #843652); }
.time-event.descanso { background: linear-gradient(135deg, #d4a437, #b08828); }
.time-event.hobby { background: linear-gradient(135deg, #d97757, #b85a3d); }
.time-event.habito { background: linear-gradient(135deg, #4d6b4a, #2f4530); }

.event-title {
  font-size: 13px;
  font-weight: 700;
}

.event-duration {
  font-size: 11px;
  opacity: 0.85;
  margin-top: 2px;
}

.event-pts {
  position: absolute;
  top: 12px;
  right: 14px;
  background: rgba(255, 255, 255, 0.25);
  padding: 2px 8px;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 700;
  backdrop-filter: blur(8px);
}

.empty-slot {
  flex: 1;
  border: 1.5px dashed var(--cream-2);
  border-radius: 14px;
  padding: 12px;
  font-size: 12px;
  color: var(--ink-muted);
  text-align: center;
  font-style: italic;
}

/* === TIENDA === */
.shop-header {
  padding: 24px 20px 20px;
  margin: 16px 20px 16px;
  background: linear-gradient(135deg, #1a1410 0%, #3d342c 100%);
  color: var(--cream);
  position: relative;
  overflow: hidden;
  border-radius: 24px;
}

.shop-header::before {
  content: '';
  position: absolute;
  top: -30px;
  right: -30px;
  width: 140px;
  height: 140px;
  background: radial-gradient(circle, rgba(212, 164, 55, 0.4), transparent 70%);
}

.shop-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 2;
  gap: 10px;
}

.shop-title {
  font-family: 'Fraunces', serif;
  font-size: 24px;
  font-weight: 900;
  font-style: italic;
  line-height: 1;
}

.coin-badge {
  background: var(--gold);
  color: var(--ink);
  padding: 8px 12px;
  border-radius: 20px;
  font-weight: 800;
  font-size: 14px;
  display: flex;
  align-items: center;
  gap: 4px;
  white-space: nowrap;
  flex-shrink: 0;
}

.shop-subtitle {
  font-size: 12px;
  opacity: 0.75;
  margin-top: 10px;
  font-style: italic;
  position: relative;
  z-index: 2;
}

.reward-grid {
  padding: 0 20px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.reward {
