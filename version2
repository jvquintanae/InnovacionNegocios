<script>
function goTo(id, btn) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function toggleMission(el, state) {
  if (el.classList.contains('done')) {
    el.classList.remove('done');
  } else {
    el.classList.add('done');
    showToast('✨ ¡Misión cumplida! +pts para Sage');
  }
}

function toggleTask(el) {
  if (el.classList.contains('done')) {
    el.classList.remove('done');
  } else {
    el.classList.add('done');
    const pts = el.querySelector('.task-pts').textContent;
    showToast('✨ ¡Hecho! ' + pts + ' pts');
  }
}

function openModal() {
  document.getElementById('modal').classList.add('show');
}

function closeModal() {
  document.getElementById('modal').classList.remove('show');
}

function closeModalIfBg(e) {
  if (e.target.id === 'modal') closeModal();
}

function selectCat(el) {
  document.querySelectorAll('.cat-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
}

function getCatInfo() {
  const selected = document.querySelector('.cat-opt.selected');
  if (!selected) return { key: 'descanso', emoji: '🌅', label: 'Descanso', pts: 25 };
  const txt = selected.textContent.trim();
  if (txt.includes('Estudio')) return { key: 'estudio', emoji: '📚', label: 'Estudio', pts: 30 };
  if (txt.includes('Trabajo')) return { key: 'trabajo', emoji: '💼', label: 'Trabajo', pts: 25 };
  if (txt.includes('Hábito')) return { key: 'habito', emoji: '🌱', label: 'Hábito', pts: 15 };
  if (txt.includes('Descanso')) return { key: 'descanso', emoji: '🌅', label: 'Descanso', pts: 25 };
  if (txt.includes('Hobby')) return { key: 'hobby', emoji: '🎸', label: 'Hobby', pts: 40 };
  if (txt.includes('Social')) return { key: 'habito', emoji: '👥', label: 'Social', pts: 20 };
  return { key: 'descanso', emoji: '🌅', label: 'Descanso', pts: 25 };
}

function addTask() {
  const name = document.getElementById('task-name-input').value || 'Nueva misión';
  const time = document.getElementById('task-time-input').value || '18:00';
  const cat = getCatInfo();

  // Insertar en el timeline del calendario
  const timeline = document.getElementById('timeline');
  if (timeline) {
    const block = document.createElement('div');
    block.className = 'time-block new-block';
    block.innerHTML = `
      <div class="time-label">${time}</div>
      <div class="time-event ${cat.key}">
        <div class="event-title">${cat.emoji} ${name}</div>
        <div class="event-duration">Recién agregado</div>
        <div class="event-pts">+${cat.pts}</div>
      </div>
    `;
    timeline.appendChild(block);
  }

  // Insertar también en la lista de pendientes
  const taskGroup = document.querySelector('#screen-tasks .task-group');
  if (taskGroup) {
    const card = document.createElement('div');
    card.className = 'task-card new-block';
    card.onclick = function() { toggleTask(this); };
    card.innerHTML = `
      <div class="task-icon ${cat.key}">${cat.emoji}</div>
      <div class="task-body">
        <div class="task-name">${name}</div>
        <div class="task-time">⏱ ${time} · nueva</div>
      </div>
      <div class="task-pts">+${cat.pts}</div>
    `;
    taskGroup.appendChild(card);
  }

  closeModal();
  showToast('✅ "' + name.slice(0, 20) + '" agregada · +' + cat.pts + ' pts');
  document.getElementById('task-name-input').value = '';
}

function claim(el, cost) {
  if (el.classList.contains('locked')) return;
  showToast('🎉 ¡Recompensa canjeada! Disfrútala');
}

let toastTimeout;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimeout);
  toastTimeout = setTimeout(() => t.classList.remove('show'), 2500);
}

let pauseActive = false;
function togglePause() {
  pauseActive = !pauseActive;
  const banner = document.getElementById('pauseBanner');
  const btn = document.querySelector('.pause-btn');
  if (pauseActive) {
    banner.classList.add('visible');
    btn.classList.add('active');
    showToast('🌿 Modo pausa activado · Sage descansa contigo');
  } else {
    banner.classList.remove('visible');
    btn.classList.remove('active');
    showToast('☀️ Bienvenida de vuelta');
  }
}

function dismissAlert(accept) {
  const alert = document.getElementById('smartAlert');
  alert.style.display = 'none';
  if (accept) {
    showToast('🌱 Moví 2 tareas a mañana sin culpa');
  } else {
    showToast('💚 Está bien, tú decides');
  }
}
</script>
